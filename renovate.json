{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "matchFileNames": ["nixpkgs/modac-dev-machine/**"],
      "enabled": false,
      "description": "Disable Go module updates for modac-dev-machine (requires manual vendorHash update in flake.nix)"
    },
    {
      "matchDepNames": ["sadjow/claude-code-nix"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "description": "Auto-merge claude-code-nix tag/digest bumps"
    }
  ],
  "regexManagers": [
    {
      "fileMatch": ["^provisioning/vars/tooling_version.yml$", "^devbox/provision$"],
      "matchStrings": [
        "datasource=(?<datasource>.*?) depName=(?<depName>.*?)( versioning=(?<versioning>.*?))?\\n.*?:\\s\"(?<currentValue>.*)\"\\s"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"
    },
    {
      "fileMatch": ["^devbox/plugins/modac/plugin\\.json$"],
      "matchStrings": [
        "github:sadjow/claude-code-nix/(?<currentValue>v[0-9.]+)#claude-code"
      ],
      "depNameTemplate": "sadjow/claude-code-nix",
      "packageNameTemplate": "https://github.com/sadjow/claude-code-nix",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver"
    }
  ]
}
